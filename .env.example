# -----------------------------------------------------------------------------
# MotherDuck Postgres endpoint
# -----------------------------------------------------------------------------
# Copy this file to `.env.local` and fill in the values below.
#
# When deploying on Vercel, the easiest path is the MotherDuck Native
# Integration (https://vercel.com/marketplace/motherduck) — it provisions
# a database and sets these variables for you automatically.
#
# To run locally against your own MotherDuck account:
#   1. Sign up / log in at https://app.motherduck.com
#   2. Create a read/write access token at
#      https://app.motherduck.com/settings/tokens
#   3. Paste the token below.
#
# Docs: https://motherduck.com/docs/key-tasks/authenticating-and-connecting-to-motherduck/postgres-endpoint
# -----------------------------------------------------------------------------

# Required — your MotherDuck access token (JWT).
MOTHERDUCK_TOKEN=

# Optional — the Postgres endpoint host for your MotherDuck region.
# Defaults to the US-East region. 
# Find the Postgres endpoint url for your region: https://app.motherduck.com/settings/postgres
MOTHERDUCK_HOST=pg.us-east-1-aws.motherduck.com

